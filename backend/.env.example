APP_NAME=Apify QA Bot
APP_ENV=development
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Local development
DATABASE_URL=sqlite:///./data/app.db

# Production example for Supabase Postgres:
# DATABASE_URL=postgresql+psycopg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

LLM_PROVIDER=nvidia
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_CHAT_MODEL=meta/llama-3.1-70b-instruct
LLM_EMBEDDING_MODEL=llama-3_2-nemoretriever-300m-embed-v1
LLM_EMBEDDING_QUERY_INPUT_TYPE=
LLM_EMBEDDING_DOCUMENT_INPUT_TYPE=

OPENAI_API_KEY=
NVIDIA_API_KEY=

APIFY_API_TOKEN=
APIFY_ACTOR_ID=apify/website-content-crawler

CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=5
